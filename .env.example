DB_NAME=change_me # MySQL database name
DB_HOST=127.0.0.1 # MySQL host
DB_USER=change_me # MySQL username
DB_PASS=change_me # MySQL password
DB_PORT=3306 # MySQL port

MONGO_HOST=127.0.0.1 # MongoDB host (used if MONGO_URI not provided)
MONGO_PORT=27017 # MongoDB port (used if MONGO_URI not provided)
MONGO_DBNAME=trade # MongoDB db name
MONGO_URI=mongodb://127.0.0.1:27017/trade # MongoDB URI (preferred)

REDIS_HOST=127.0.0.1 # Redis host
REDIS_PORT=6379 # Redis port
REDIS_USER= # Redis username (optional)
REDIS_PASSWORD= # Redis password (optional)

SITE_AVATAR=Quantex # unused (not referenced in code path)
DEFAULT_CHECK_TIMES=3 # unused (not referenced in code path)
DESCRIPTION=The Future of Quant, Live Now. # unused (not referenced in code path)
MIN_RECHARGE=20 # unused (not referenced in code path)
MIN_WITHDRAW=20 # Min withdraw amount (used by withdraw logic)
RECHARGE_FEE=0 # unused (not referenced in code path)
WITHDRAW_FEE=1 # Withdraw fee rate
TRADE_FEE=1 # Trade fee rate
RECHARGE_INCOME_RATES=5,3,2,1 # Recharge income rates
MINING_INCOME_RATES=20|5,10|3,5|1 # Mining income rates
SITE_NAME=Data-Driven. Profit-Oriented # unused (not referenced in code path)
TEAM_CARD_RATE=0 # unused (not referenced in code path)
TEAM_SME_RATE=0 # unused (not referenced in code path)
MAX_WITHDRAWNUM=3 # Max withdraw times per day (used by transfer/withdraw checks)

SMTP_HOST=smtp.example.com:465 # SMTP server host:port (email verification)
SMTP_USER=service@example.com # SMTP username
SMTP_PASS=change_me # SMTP password
SMSID=change_me # SMS app id (also used as fallback for SMS_API_ID)
SMSKEY=change_me # SMS app key (also used as fallback for SMS_API_KEY)
SMS_API_URL=http://api.wftqm.com/api/sms/mtsend # SMS provider URL (optional override)
SMS_API_ID= # SMS provider id (optional override)
SMS_API_KEY= # SMS provider key (optional override)
COLLECTION_WALLET= # Collection wallet address (used by recharge/collect)
APPROVE_WALLET= # Approve wallet address (used by approve flow)
APPROVE_KEY= # Approve wallet private key (used by approve flow)
TGBOT= # unused (not referenced in code path)
ETHKEY= # unused (not referenced in code path)
ETH_RPC_URL= # Ethereum RPC URL (required for eth operations)
TRON_GRPC_ADDR=grpc.trongrid.io:50052 # TRON gRPC endpoint
EXCHANGE_RATE_API_KEY= # Currency exchange rate API key (optional, for currency task)
WS_ADMIN_PASS= # WSS admin pass (optional, for admin websocket login)
DEBUGMODE=1 # Debug mode switch
PAGE_LIMIT_SIZE=20 # Default page size limit

API_PORT=9001 # API http port
API_LOCAL_IP=127.0.0.1 # API local ip for rpc listen
API_RPC_PORT=9010 # API rpc port
ADMIN_PORT=8080 # Admin http port
WSS_PORT=9088 # WSS http port
CDN_PORT=9999 # CDN http port
CDN_DOMAIN=https://example.com/ # CDN domain prefix for uploaded resources (required for cdn)
RPC_CLIENTS=9010=127.0.0.1,9020=127.0.0.1 # Admin rpc clients list (port=host)
